# Credit Caddy catalog agent — local secrets template.
#
# Copy this file to ~/.config/credit-caddy/secrets.env on the Mac mini,
# fill in your real FireCrawl key, then chmod 600 it:
#
#   mkdir -p ~/.config/credit-caddy
#   cp ~/credit-caddy-card-catalog/local/secrets.env.example ~/.config/credit-caddy/secrets.env
#   $EDITOR ~/.config/credit-caddy/secrets.env
#   chmod 600 ~/.config/credit-caddy/secrets.env
#
# DO NOT commit this file with real values. It lives outside the repo intentionally.

FIRECRAWL_API_KEY=fc-REPLACE_ME
