{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Credit Caddy Card Catalog",
  "type": "object",
  "required": ["schemaVersion", "version", "lastUpdated", "cards"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Catalog schema version. Bumps only on breaking client changes."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d{4}\\.\\d{2}\\.\\d{2}$",
      "description": "YYYY.MM.DD. Advances on every merge to main. Compared lexicographically by clients."
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of the last catalog update."
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/card" }
    }
  },
  "$defs": {
    "card": {
      "type": "object",
      "required": [
        "id",
        "cardName",
        "issuer",
        "annualFee",
        "noForeignTransactionFees",
        "earnRates",
        "baseEarnRate",
        "rewardProgram",
        "benefits"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Stable slug. Never changes after a card is added to the catalog."
        },
        "cardName": { "type": "string", "minLength": 1 },
        "issuer": { "type": "string", "minLength": 1 },
        "annualFee": { "type": "number", "minimum": 0, "maximum": 1500 },
        "noForeignTransactionFees": { "type": "boolean" },
        "earnRates": {
          "type": "array",
          "items": { "$ref": "#/$defs/earnRate" }
        },
        "baseEarnRate": { "type": "number", "minimum": 0.5, "maximum": 20 },
        "rewardProgram": { "type": "string" },
        "affiliateUrl": { "type": ["string", "null"], "format": "uri" },
        "colorHex": {
          "type": ["string", "null"],
          "pattern": "^[0-9A-Fa-f]{6}$"
        },
        "benefits": {
          "type": "array",
          "items": { "$ref": "#/$defs/benefit" }
        },
        "discontinued": { "type": "boolean" },
        "lastVerified": { "type": "string", "format": "date-time" },
        "sources": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/sourceRef" },
          "description": "Map from field path (e.g. 'annualFee' or 'benefits.uber-cash') to citation URL(s). Any value listed here must be on the issuer's own domain and return HTTP 2xx."
        }
      }
    },
    "sourceRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^https://"
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "string", "pattern": "^https://" },
          "description": "Used for annualFee on change: two independent citations on the issuer's domain."
        }
      ]
    },
    "earnRate": {
      "type": "object",
      "required": ["category", "multiplier"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "airfare",
            "dining",
            "drugstores",
            "gas",
            "groceries",
            "hotels",
            "onlineShopping",
            "other",
            "rent",
            "streaming",
            "transit",
            "travel"
          ]
        },
        "multiplier": { "type": "number", "minimum": 0.5, "maximum": 20 },
        "cap": { "type": ["number", "null"], "minimum": 0 },
        "isConditional": {
          "type": "boolean",
          "description": "True when the multiplier requires a specific booking channel (Amex Travel, issuer portal, direct with merchant). False for everywhere-applicable category bonuses."
        },
        "timeWindows": {
          "type": "array",
          "description": "Local time windows where a time-sensitive conditional rate is active.",
          "items": {
            "type": "object",
            "required": ["days", "startMinute", "endMinute"],
            "additionalProperties": false,
            "properties": {
              "days": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "sunday",
                    "monday",
                    "tuesday",
                    "wednesday",
                    "thursday",
                    "friday",
                    "saturday"
                  ]
                }
              },
              "startMinute": { "type": "integer", "minimum": 0, "maximum": 1439 },
              "endMinute": { "type": "integer", "minimum": 0, "maximum": 1440 },
              "timeZone": { "type": "string", "minLength": 1 }
            }
          }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "benefit": {
      "type": "object",
      "required": ["name", "renewalPeriod", "periodBasis", "category", "allowsPartialUse", "notificationsEnabled"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "amount": { "type": ["number", "null"], "minimum": 0, "maximum": 5000 },
        "renewalPeriod": {
          "type": "string",
          "enum": ["Monthly", "Every 3 months", "Every 6 months", "Yearly"]
        },
        "periodBasis": {
          "type": "string",
          "enum": ["Calendar Year", "Cardmember Year"]
        },
        "category": { "type": "string" },
        "allowsPartialUse": { "type": "boolean" },
        "requiresValueOnUse": { "type": "boolean" },
        "notes": { "type": ["string", "null"] },
        "availableMonths": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 12 }
        },
        "notificationsEnabled": { "type": "boolean" }
      }
    }
  }
}
